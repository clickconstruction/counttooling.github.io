{
  "name": "counttooling",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:icons": "node scripts/build-custom-icons.js",
    "build:toc": "node scripts/build-toc.js",
    "lint": "eslint .",
    "test": "playwright test",
    "test:unit": "node --test",
    "precloudtest": "node scripts/generate-config.js",
    "test:cloud": "npm run precloudtest && playwright test load-project-delete.spec.js load-project-empty-pdf.spec.js",
    "test:delete-page": "playwright test delete-page.spec.js",
    "test:load-project-delete": "playwright test load-project-delete.spec.js",
    "test:load-project-empty-pdf": "playwright test load-project-empty-pdf.spec.js",
    "test:upload-then-save": "playwright test upload-then-save.spec.js",
    "test:indexeddb-backup": "playwright test indexeddb-backup.spec.js",
    "test:custom-icon-paths": "playwright test custom-icon-paths-indexeddb.spec.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.0",
    "eslint": "^9.39.4",
    "globals": "^17.6.0"
  }
}
